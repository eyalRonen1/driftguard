{
  "crons": [
    {
      "path": "/api/internal/dispatch-scans",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/weekly-digest",
      "schedule": "0 8 * * 1"
    }
  ],
  "functions": {
    "app/api/v1/monitors/[monitorId]/check/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/internal/dispatch-scans/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/internal/weekly-digest/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
